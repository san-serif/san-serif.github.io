---
/* ABOUT PAGE - san serif
  Independent studio biography and philosophy.
  Asset: public/images/fuji.png
*/
import Layout from '../layouts/Layout.astro';
---

<Layout title="About | san serif">
	<main class="wrapper">

		<section class="bio">
			<header class="hero-header">
				<img src="/images/fuji.png" alt="Mt Fuji Sketch" class="fuji-bg" />
				<h1>san serif</h1>
			</header>

			<div class="content">
				<p>
					The name <strong>san</strong> comes from the character <strong>山 (san)</strong> meaning “mountain”. It serves as a reminder of the discipline required when navigating the complexities of Japanese, Korean, and Chinese.
				</p>
				
				<p>
					Based in Sydney, san serif is an independent studio focused on building high-utility tools for language learning and culture. Each product is designed to remove friction from the learning process and support consistent, deliberate progress.
				</p>

				<div class="divider"></div>

				<div class="philosophy-section">
					<h3>The Philosophy</h3>
					<p>
						User-friendly, Apple-native tools for language learning. Minimal friction, long-term retention.
					</p>
				</div>

				<div class="divider"></div>

				<div class="footer-bio">
					<p>Building tools for the journey</p>
				</div>
			</div>
		</section>

	</main>
</Layout>

<style>
	/* --- LAYOUT CONFIG --- */
	.wrapper { 
		max-width: 850px; 
		margin: 0 auto; 
		/* Keeps the whole section high up on the screen */
		padding: 20px 20px 80px; 
	}

	/* --- HERO / MOUNTAIN SECTION --- */
	.hero-header {
		display: flex;
		flex-direction: column; 
		align-items: flex-start;
		margin-bottom: 60px;
	}

	.fuji-bg {
		width: 480px;
		opacity: 1;
		filter: grayscale(100%);
		mix-blend-mode: multiply; 
		
		/* Pulls the image to the top of the viewport */
		margin-top: -30px; 
		margin-left: -20px;
		
		/* Adds the requested space between mountain and heading */
		margin-bottom: 15px; 
		
		pointer-events: none; 
		user-select: none;
	}
	
	/* --- TYPOGRAPHY --- */
	h1 { 
		font-size: 3.2rem; 
		font-weight: 700; 
		letter-spacing: -0.04em; 
		margin: 0;
		color: #000;
	}
	
	.content p { 
		font-size: 1.1rem; 
		line-height: 1.7; 
		color: #333; 
		margin-bottom: 2rem; 
	}
	
	.content strong { font-weight: 600; color: #000; }
	
	/* --- DECORATIVE --- */
	.divider { height: 1px; background: #eee; margin: 50px 0; }
	.philosophy-section { max-width: 600px; }

	h3 { 
		font-size: 0.75rem; 
		text-transform: uppercase; 
		letter-spacing: 0.1rem; 
		color: #999; 
		margin-bottom: 15px; 
		font-weight: 700; 
	}
	
	.philosophy-section p { font-size: 1rem; color: #555; line-height: 1.6; }
	
	.footer-bio p { 
		font-size: 0.95rem; 
		color: #bbb; 
		letter-spacing: 0.02em; 
		font-weight: 500; 
	}

	/* --- RESPONSIVE --- */
	@media (max-width: 700px) {
		.wrapper { padding-top: 10px; }
		h1 { font-size: 2.6rem; }
		.fuji-bg {
			width: 100%;
			max-width: 400px;
			margin-top: -10px;
			/* Ensures breathing room remains on mobile */
			margin-bottom: 10px; 
		}
	}
</style>
