---
/* 
  ABOUT PAGE - san serif
  Independent studio biography and philosophy.
*/
import Layout from '../layouts/Layout.astro';
---

<Layout title="About | san serif">
	<main class="wrapper">

		<!-- SECTION: BIO HEADER -->
		<section class="bio">
			<header>
				<h1>san serif</h1>
			</header>

			<div class="content">
				<!-- The Brand Story: Explaining 'san' (山) -->
				<p>
					The name <strong>san</strong> comes from the character <strong>山 (san)</strong> meaning “mountain”. It serves as a reminder of the discipline required when navigating the complexities of Japanese, Korean, and Chinese.
				</p>
				
				<!-- The Studio Mission -->
				<p>
					Based in Sydney, san serif is an independent studio focused on building high-utility tools for language learning and culture. Each product is designed to remove friction from the learning process and support consistent, deliberate progress.
				</p>

				<div class="divider"></div>

				<!-- THE PHILOSOPHY: Core Design & Product Pillars -->
				<div class="philosophy-section">
					<h3>The Philosophy</h3>
					<p>
						User-friendly, Apple-native tools for language learning. Minimal friction. Structured progress. Long-term retention.
					</p>
				</div>

				<div class="divider"></div>

				<!-- FOOTER: Final brand sign-off -->
				<div class="footer-bio">
					<p>Building tools for the journey</p>
				</div>
			</div>
		</section>

	</main>
</Layout>

<style>
	/* --- LAYOUT CONFIG --- */
	.wrapper { 
		max-width: 850px; 
		margin: 0 auto; 
		padding: 80px 20px; 
	}
	
	/* --- TYPOGRAPHY --- */
	h1 { 
		font-size: 3rem; 
		font-weight: 700; 
		letter-spacing: -0.03em; 
		margin-bottom: 50px; 
	}
	
	.content p { 
		font-size: 1.1rem; 
		line-height: 1.7; 
		color: #333; 
		margin-bottom: 2rem; 
	}
	
	.content strong { 
		font-weight: 600; 
		color: #000; 
	}
	
	/* --- DECORATIVE ELEMENTS --- */
	.divider { 
		height: 1px; 
		background: #eee; /* Changed from #ffffff to be visible on white BG */
		margin: 50px 0; 
	}

	/* --- PHILOSOPHY SECTION --- */
	.philosophy-section { 
		max-width: 600px; 
	}

	h3 { 
		font-size: 0.75rem; 
		text-transform: uppercase; 
		letter-spacing: 0.1rem; 
		color: #999; 
		margin-bottom: 15px; 
		font-weight: 700; 
	}
	
	.philosophy-section p { 
		font-size: 1rem; 
		color: #555; 
		line-height: 1.6; 
	}

	/* --- FOOTER BIO --- */
	.footer-bio p { 
		font-size: 0.95rem; 
		color: #bbb; 
		letter-spacing: 0.02em; 
		font-weight: 500; 
	}

	/* --- RESPONSIVE --- */
	@media (max-width: 600px) {
		h1 { 
			font-size: 2.5rem; 
		}
	}
</style>
