---
import Layout from '../layouts/Layout.astro';
---

<Layout title="About | san serif">
	<main class="wrapper">

		<section class="bio">
			<header>
				<h1>san serif</h1>
			</header>

			<div class="content">
				<p>
					The name <strong>san</strong> comes from the character <strong>山 (san)</strong>  meaning “mountain”. It serves as a reminder of the discipline required when navigating the complexities of Japanese, Korean, and Chinese.
				</p>
				
				<p>
					Based in Sydney, san serif is an independent studio focused on building high-utility tools for language learning and culture. Each product is designed to remove friction from the learning process and make progress feel more deliberate.
				</p>

				<div class="divider"></div>

				<div class="philosophy-section">
					<h3>The Philosophy</h3>
					<p>
						san serif builds focused, Apple-native tools for language learning. Each product is designed to reduce friction and support consistent, structured progress.
						
					</p>
				</div>

				<div class="divider"></div>

				<div class="footer-bio">
					<p>Building tools for the journey</p>
				</div>
			</div>
		</section>

	</main>
</Layout>

<style>
	.wrapper { 
		max-width: 850px; 
		margin: 0 auto; 
		padding: 80px 20px; 
	}
	
	h1 { 
		font-size: 3rem; 
		font-weight: 700; 
		letter-spacing: -0.03em; 
		margin-bottom: 50px; 
	}
	
	.content p { 
		font-size: 1.1rem; 
		line-height: 1.7; 
		color: #333; 
		margin-bottom: 2rem; 
	}
	
	.content strong { 
		font-weight: 600; 
		color: #000; 
	}
	
	.divider { 
		height: 1px; 
		background: #ffffff; 
		margin: 50px 0; 
	}

	.philosophy-section { 
		max-width: 600px; 
	}

	h3 { 
		font-size: 0.75rem; 
		text-transform: uppercase; 
		letter-spacing: 0.1rem; 
		color: #999; 
		margin-bottom: 15px; 
		font-weight: 700; 
	}
	
	.philosophy-section p { 
		font-size: 1rem; 
		color: #555; 
		line-height: 1.6; 
	}

	.footer-bio p { 
		font-size: 0.95rem; 
		color: #bbb; 
		letter-spacing: 0.02em; 
		font-weight: 500; 
	}

	@media (max-width: 600px) {
		h1 { 
			font-size: 2.5rem; 
		}
	}
</style>