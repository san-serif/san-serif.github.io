---
/* 
  ABOUT PAGE - san serif
  Independent studio biography and philosophy.
  Asset: public/images/fuji-bg.png (100% opacity grey export)
*/
import Layout from '../layouts/Layout.astro';
---

<Layout title="About | san serif">
	<main class="wrapper">

		<section class="bio">
			<header class="hero-header">
				<!-- The Fuji Asset: Anchored to the right -->
				<img src="/images/fuji.png" alt="" class="fuji-bg" />
				<h1>san serif</h1>
			</header>

			<div class="content">
				<p>
					The name <strong>san</strong> comes from the character <strong>山 (san)</strong> meaning “mountain”. It serves as a reminder of the discipline required when navigating the complexities of Japanese, Korean, and Chinese.
				</p>
				
				<p>
					Based in Sydney, san serif is an independent studio focused on building high-utility tools for language learning and culture. Each product is designed to remove friction from the learning process and support consistent, deliberate progress.
				</p>

				<div class="divider"></div>

				<div class="philosophy-section">
					<h3>The Philosophy</h3>
					<p>
						User-friendly, Apple-native tools for language learning. Minimal friction. Structured progress. Long-term retention.
					</p>
				</div>

				<div class="divider"></div>

				<div class="footer-bio">
					<p>Building tools for the journey</p>
				</div>
			</div>
		</section>

	</main>
</Layout>

<style>
	/* --- LAYOUT CONFIG --- */
	.wrapper { 
		max-width: 850px; 
		margin: 0 auto; 
		padding: 80px 20px; 
	}

	/* --- HERO / MOUNTAIN SECTION --- */
	.hero-header {
		position: relative; 
		margin-bottom: 80px;
		display: flex;
		align-items: flex-end;
		overflow: visible;
	}

	.fuji-bg {
		position: absolute;
		/* Anchored to the right to avoid overlapping the "san" */
		top: -70px; 
		right: -40px; 
		width: 480px;
		
		/* VISIBILITY SETTINGS */
		z-index: 0;           /* Set to 0 so it's above the background but below h1 */
		opacity: 1;        /* Increased slightly so it's visible on all monitors */
		
		pointer-events: none; 
		user-select: none;
		filter: grayscale(100%);
	}
	
	/* --- TYPOGRAPHY --- */
	h1 { 
		font-size: 3.2rem; 
		font-weight: 700; 
		letter-spacing: -0.04em; 
		margin: 0;
		color: #000;
		position: relative;   /* Required for z-index */
		z-index: 10;          /* Guarantees text is always on top */
	}
	
	.content p { 
		font-size: 1.1rem; 
		line-height: 1.7; 
		color: #333; 
		margin-bottom: 2rem; 
	}
	
	.content strong { font-weight: 600; color: #000; }
	
	/* --- DECORATIVE --- */
	.divider { height: 1px; background: #eee; margin: 50px 0; }

	.philosophy-section { max-width: 600px; }

	h3 { 
		font-size: 0.75rem; 
		text-transform: uppercase; 
		letter-spacing: 0.1rem; 
		color: #999; 
		margin-bottom: 15px; 
		font-weight: 700; 
	}
	
	.philosophy-section p { font-size: 1rem; color: #555; line-height: 1.6; }
	
	.footer-bio p { 
		font-size: 0.95rem; 
		color: #bbb; 
		letter-spacing: 0.02em; 
		font-weight: 500; 
	}

	/* --- RESPONSIVE --- */
	@media (max-width: 700px) {
		h1 { font-size: 2.6rem; }
		.fuji-bg {
			width: 400px;
			top: -40px;
			right: -10px;
			opacity: 1; /* Keep it even fainter on mobile */
		}
	}
</style>
