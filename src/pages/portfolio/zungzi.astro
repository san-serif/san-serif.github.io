---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Zungzi | san serif">
	<main class="wrapper">

		<section class="app-hero">

			<div class="video-container">
				<div class="video-glow"></div>

				<video 
					autoplay 
					loop 
					muted 
					playsinline 
					webkit-playsinline
					poster="/images/zungzi-poster.jpg" 
					class="hero-watch-video"
					style="background-color: transparent !important;"
				>
					<source src="/videos/zungzi-ultra.mp4" type="video/mp4">
				</video>
			</div>

			<div class="app-intro">
				<h1>Zungzi</h1>

				<p class="description">
					Modern Chinese flashcards built for the Apple Watch. A high-frequency character tool designed to help you master tones and Hanzi in the gaps of your day.
				</p>

				<a href="#" class="app-store-link">
					<img src="/images/app-store-badge.svg" alt="Download on the App Store" class="badge-svg" />
				</a>
			</div>

		</section>

		<div class="divider"></div>

		<section class="details-grid">

			<div class="detail-card">
				<div class="floating-container">
					<img src="/images/zungzi-tones.png" alt="Tone Precision" class="modular-image" />
				</div>
				<h3>Tone Precision</h3>
				<p>Visual and haptic cues for the four tones. Master the pitch of every character without needing to look at your phone.</p>
			</div>

			<div class="detail-card">
				<div class="floating-container">
					<img src="/images/zungzi-hsk.png" alt="HSK Structure" class="modular-image" />
				</div>
				<h3>HSK Structure</h3>
				<p>Built around the HSK 3.0 curriculum, organising vocabulary into clear, progressive levels.</p>
			</div>

			<div class="detail-card">
				<div class="floating-container">
					<img src="/images/zungzi-stroke.png" alt="Hanzi Clarity" class="modular-image" />
				</div>
				<h3>Hanzi Clarity</h3>
				<p>Support for both simplified and traditional Chinese characters, designed for clear reading at a glance.</p>
			</div>

		</section>

	</main>
</Layout>

<style>
	.wrapper {
		max-width: 1100px;
		margin: 0 auto;
		padding: 0 20px;
	}

	h1, h3, p {
		margin: 0;
	}

	/* --- HERO --- */
	.app-hero { 
		display: flex;
		flex-direction: column;
		align-items: center;
		text-align: center;
		padding-top: 30px;
		gap: 24px;
		isolation: isolate;
	}

	.video-container { 
		position: relative;
		width: 100%;
		max-width: 380px;
		display: flex;
		justify-content: center;
		transform: translateY(-10px);
		transition: transform 0.6s ease;
	}

	.hero-watch-video { 
		width: 100%; 
		height: auto; 
		display: block;
		transform: translateZ(0);
		will-change: contents;
		border: none;
		background: transparent !important;
	}

	/* --- TEXT --- */
	h1 {
		font-size: 3.5rem;
		font-weight: 600;
		letter-spacing: -0.05em;
		margin-bottom: 8px;
		color: #111;
	}

	.description {
		max-width: 580px;
		font-size: 1.2rem;
		color: #555;
		line-height: 1.6;
		margin-bottom: 28px;
	}

	/* ✅ FIXED BUTTON ALIGNMENT (this was your issue) */
	.app-store-link {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		line-height: 0;
	}

	.badge-svg {
		height: 52px;
		width: auto;
		display: block;
	}

	/* --- SPACING (MATCH TOKEITANGO FEEL) --- */
	.divider {
		height: 1px;
		background: transparent;
		margin: 90px 0;
	}

	/* --- GRID --- */
	.details-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 60px;
		margin-bottom: 120px;
	}

	.detail-card {
		display: flex;
		flex-direction: column;
		align-items: center;
		text-align: center;
	}

	.floating-container {
		width: 100%;
		display: flex;
		align-items: center;
		justify-content: center;
		margin-bottom: 6px;
	}

	.modular-image {
		width: 70%;
		border-radius: 20px;
		opacity: 0.9;
		box-shadow: 0 15px 45px rgba(0,0,0,0.1);
		transition: all 0.5s cubic-bezier(0.165, 0.84, 0.44, 1);
	}

	.detail-card:hover .modular-image {
		transform: scale(1.04) translateY(-8px);
		opacity: 1;
	}

	h3 {
		font-size: 0.75rem;
		text-transform: uppercase;
		font-weight: 700;
		letter-spacing: 0.12em;
		margin-bottom: 10px;
		color: #111;
	}

	.detail-card p {
		font-size: 0.95rem;
		color: #555;
		line-height: 1.7;
		max-width: 260px;
	}

	@media (max-width: 900px) {
		.details-grid { grid-template-columns: 1fr; gap: 60px; }
		.divider { margin: 60px 0; }
		.video-container { max-width: 320px; }
	}
</style>