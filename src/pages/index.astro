---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Portfolio | san serif">
	<main class="wrapper">
		<section class="grid">

			{/* SAJEON */}
			<a href="/portfolio/sajeon" class="card sajeon">
				<img src="/sajeon-icon.png" alt="Sajeon" class="app-icon hero-icon" />
				<div class="card-content">
					<span class="category">iOS, iPadOS, macOS / KR</span>
					<h2>Sajeon</h2>
					<p>
						A native Korean dictionary built for deep immersion. Beyond rapid search, Sajeon features a powerful clipboard reader to deconstruct complex sentences for translation and shadow reading. Curate your progress with custom word lists and extensive catalogue of vocabulary, all within a distilled interface that stays out of your way.
					</p>
				</div>
			</a>

			{/* TOKEITANGO */}
			<a href="/portfolio/tokeitango" class="card tokei">
				<img src="/tokeitango-icon.png" alt="tokeitango" class="app-icon hero-icon" />
				<div class="card-content">
					<span class="category">watchOS / JP</span>
					<h2>TokeiTango</h2>
					<p>
						JLPT vocabulary and study sessions, reimagined for the wrist. Discreet, haptic-driven reviews designed for immersion on the go.
					</p>
				</div>
			</a>

			{/* EOHWI */}
			<a href="/portfolio/eohwi" class="card eohwi">
				<img src="/eohwi-icon.png" alt="Eohwi" class="app-icon standard-icon" />
				<div class="card-content">
					<span class="category">watchOS / KR</span>
					<h2>Eohwi</h2>
					<p>Master TOPIK vocabulary on the go. Bite-sized Korean flashcards and smart spaced repetition directly on your Apple Watch.</p>
				</div>
			</a>

			{/* ZUNGZI */}
			<a href="/portfolio/zungzi" class="card zungzi">
				<img src="/zungzi-icon.png" alt="Zungzi" class="app-icon standard-icon" />
				<div class="card-content">
					<span class="category">watchOS / CN</span>
					<h2>Zungzi</h2>
					<p>Conquer Chinese Hanzi from anywhere. Practice HSK characters with quick-glance reviews and Mandarin/Cantonese audio.</p>
				</div>
			</a>

			{/* UTILITIES */}
			<a href="https://apps.apple.com/us/app-bundle/asian-language-menubar/id1793885201?mt=12" class="card utilities">
				<div class="icons-row">
					<img src="/jbar-icon.png" alt="JBar" class="app-icon mini" />
					<img src="/kbar-icon.png" alt="KBar" class="app-icon mini" />
					<img src="/cbar-icon.png" alt="CBar" class="app-icon mini" />
				</div>
				<div class="content">
					<span class="category">macOS / JP, KR, CN</span>
					<h2>JBar, KBar & CBar</h2>
					<p>Minimal menubar utilities that keep your target language seamlessly integrated into your daily workflow.</p>
				</div>
			</a>

		</section>
	</main>
</Layout>

<style>
.wrapper {
	padding-bottom: 100px;
}

.grid {
	display: grid;
	grid-template-columns: repeat(4, minmax(0, 1fr));
	grid-template-rows: minmax(240px, auto) minmax(240px, auto);
	gap: 20px;
}

/* BASE CARD */
.card {
	background: #ffffff;
	border: 1px solid rgba(0, 0, 0, 0.2);
	border-radius: 32px; 
	padding: 32px;
	display: flex;
	flex-direction: column;
	text-decoration: none;
	min-width: 0;
	cursor: pointer;
	transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.card-content, .content {
	display: flex;
	flex-direction: column;
	margin-top: auto; 
}

/* HOVER STATES */
.card:hover {
	transform: translateY(-6px);
	border-color: rgba(0, 0, 0, 0.1);
	background: #ffffff;
}

.sajeon {
	grid-column: 1;
	grid-row: 1 / span 2;
	background: #ffffff;
}

.tokei { grid-column: 2; grid-row: 1; background: #ffffff; }
.eohwi { grid-column: 3; grid-row: 1; background: #ffffff; }
.zungzi { grid-column: 4; grid-row: 1; background: #ffffff; }

.utilities {
	grid-column: 2 / 5;
	grid-row: 2;
	flex-direction: row;
	align-items: center;
	gap: 40px;
	background: #ffffff;
}

/* ICONS */
.app-icon {
	border-radius: 22.5%; 
	object-fit: cover;
	flex-shrink: 0;
}

.hero-icon {
	width: 96px; 
	height: 96px;
	margin-bottom: 32px; 
}

.standard-icon {
	width: 72px;
	height: 72px;
	margin-bottom: 24px;
}

.mini {
	width: 54px;
	height: 54px;
}

.icons-row {
	display: flex;
	gap: 16px;
	margin-bottom: 24px;
}

/* --- TYPOGRAPHY FIX --- */
.category {
	display: block;
	font-size: 0.725rem;
	font-weight: 700;
	
	/* The "Force Case" command */
	text-transform: none !important; 
	
	letter-spacing: 0.08em; 
	color: #999;
	margin-bottom: 8px;
}

h2 {
	margin: 0 0 12px 0;
	font-size: 1.25rem;
	font-weight: 600;
	letter-spacing: -0.01em;
	color: #111;
}

p {
	margin: 0;
	font-size: 0.9rem;
	color: #777;
	line-height: 1.5;
}

/* MOBILE */
@media (max-width: 900px) {
	.grid {
		grid-template-columns: 1fr;
		grid-template-rows: auto;
	}

	.card {
		grid-column: auto !important;
		grid-row: auto !important;
	}

	.utilities {
		flex-direction: column;
		align-items: flex-start;
		gap: 24px;
	}
	
	.utilities .content {
		margin-top: 0;
	}
}
</style>