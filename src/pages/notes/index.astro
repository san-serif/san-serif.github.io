---
/* CULTURE NOTES - san serif (Fixed Array Logic)
  - Patched: .join() used before .toLowerCase() on attributes.
  - Supports multiple categories per note.
  - Client-side filtering via URLSearchParams.
*/
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const notes = await getCollection('notes');
const sortedNotes = notes.sort(
	(a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
---

<Layout title="Notes | san serif">
	<main class="wrapper">

		<header class="page-header">
			<h1>Culture Notes</h1>
			<p class="page-subtitle">
				Beyond the dictionary: exploring the unspoken rules and nuances of language.
			</p>
			
			<div id="filter-status" class="filter-status hidden">
				Filtering by <span id="active-tag"></span>
				<a href="/notes" class="clear-filter">View All</a>
			</div>
		</header>

		<section class="notes-list" id="notes-container">
			{sortedNotes.map(note => (
				<article 
					class="note-item" 
					/* FIX: Join the array into a string before lowercasing */
					data-category={note.data.category.join(',').toLowerCase()}
				>

					<div class="note-meta">
						<span class="date">{note.data.date}</span>
						<div class="category-list">
							{note.data.category.map(cat => (
								<a href={`?tag=${cat.toLowerCase()}`} class="category-label">
									{cat.toUpperCase()}
								</a>
							))}
						</div>
					</div>

					<div class="note-content">
						<a href={`/notes/${note.id}`} class="note-link">
							<h2>{note.data.title}</h2>
						</a>
						<p>{note.data.description}</p>
					</div>

				</article>
			))}
		</section>

	</main>
</Layout>

<script>
	const filterNotes = () => {
		const params = new URLSearchParams(window.location.search);
		const tagFilter = params.get('tag')?.toLowerCase();
		
		const notes = document.querySelectorAll('.note-item');
		const status = document.getElementById('filter-status');
		const activeTagName = document.getElementById('active-tag');

		if (!tagFilter) {
			notes.forEach(note => note.classList.remove('hidden'));
			status?.classList.add('hidden');
			return;
		}

		status?.classList.remove('hidden');
		if (activeTagName) activeTagName.innerText = tagFilter.toUpperCase();

		notes.forEach(note => {
			const noteCategoriesString = note.getAttribute('data-category') || '';
			const noteCategoriesArray = noteCategoriesString.split(',');
			
			if (noteCategoriesArray.includes(tagFilter)) {
				note.classList.remove('hidden');
			} else {
				note.classList.add('hidden');
			}
		});
	};

	filterNotes();
	window.addEventListener('popstate', filterNotes);
</script>

<style>
	.wrapper {
		max-width: 850px;
		margin: 0 auto;
		padding: 60px 20px 120px;
	}

	.page-header { margin-bottom: 60px; }

	h1 {
		font-size: 3rem;
		font-weight: 700;
		letter-spacing: -0.04em;
		margin-bottom: 15px;
		color: #000;
	}

	.page-subtitle {
		color: #666;
		font-size: 1.1rem;
		max-width: 800px;
		line-height: 1.5;
		margin-bottom: 20px;
	}

	.filter-status {
		font-family: ui-monospace, SFMono-Regular, monospace;
		font-size: 0.8rem;
		color: #000;
		padding: 10px 0;
		border-top: 1px solid #eee;
		display: flex;
		gap: 15px;
		align-items: center;
	}

	#active-tag { font-weight: 700; }

	.clear-filter {
		color: #999;
		text-decoration: underline;
		font-size: 0.75rem;
	}

	.clear-filter:hover { color: #000; }

	.notes-list { border-top: 2px solid #000; }

	.note-item {
		display: grid;
		grid-template-columns: 160px 1fr;
		padding: 40px 0;
		border-bottom: 1px solid #eee;
		transition: all 0.25s cubic-bezier(0.2, 1, 0.3, 1);
		border-left: 0px solid #000;
	}

	.note-item.hidden { display: none; }

	.note-item:hover {
		padding-left: 25px;
		border-left: 6px solid #000;
		border-bottom-color: #000;
	}

	.note-meta {
		display: flex;
		flex-direction: column;
		gap: 8px;
		font-family: ui-monospace, SFMono-Regular, monospace;
	}

	.date { font-size: 0.8rem; color: #999; }

	.category-list {
		display: flex;
		flex-direction: column;
		gap: 4px;
	}

	.category-label {
		font-size: 0.65rem;
		font-weight: 800;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		color: #000;
		text-decoration: none;
		align-self: flex-start;
		border-bottom: 1px solid transparent;
	}

	.category-label:hover { border-bottom-color: #000; }

	.note-link { text-decoration: none !important; color: #000 !important; }

	h2 { font-size: 1.4rem; font-weight: 600; margin: 0 0 10px 0; line-height: 1.3; }

	.note-item:hover h2 { color: #666; }

	p { font-size: 1rem; color: #555; line-height: 1.5; margin-bottom: 0; }

	.hidden { display: none; }

	@media (max-width: 700px) {
		.note-item { grid-template-columns: 1fr; gap: 15px; padding: 30px 0; }
		.note-item:hover { padding-left: 15px; }
	}
</style>