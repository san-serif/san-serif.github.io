---
/* 
  CULTURE NOTES - san serif (Ghost Indent Edition)
  - Pure white background for zero-friction reading.
  - Structural indent on hover.
  - "Kill Blue" link logic maintained.
*/
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const notes = await getCollection('notes');
const sortedNotes = notes.sort(
	(a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
---

<Layout title="Notes | san serif">
	<main class="wrapper">

		<header class="page-header">
			<h1>Culture Notes</h1>
			<p class="page-subtitle">
				Beyond the dictionary: exploring the unspoken rules and nuances of language.
			</p>
		</header>

		<section class="notes-list">
			{sortedNotes.map(note => (
				<article class="note-item">

					<div class="note-meta">
						<span class="date">{note.data.date}</span>
						{note.data.category && (
							<span class="category-label">{note.data.category}</span>
						)}
					</div>

					<div class="note-content">
						<a href={`/notes/${note.id}`} class="note-link">
							<h2>{note.data.title}</h2>
						</a>
						<p>{note.data.description}</p>

						{note.data.tags && note.data.tags.length > 0 && (
							<div class="tags-row">
								{note.data.tags.map(tag => (
									<span class="tag">#{tag}</span>
								))}
							</div>
						)}
					</div>

				</article>
			))}
		</section>

	</main>
</Layout>

<style>
	.wrapper {
		max-width: 850px;
		margin: 0 auto;
		padding: 60px 20px 120px;
	}

	.page-header { margin-bottom: 60px; }

	h1 {
		font-size: 3rem;
		font-weight: 700;
		letter-spacing: -0.04em;
		margin-bottom: 15px;
		color: #000;
	}

	.page-subtitle {
		color: #666;
		font-size: 1.1rem;
		max-width: 520px;
		line-height: 1.5;
	}

	/* --- THE LIST --- */
	.notes-list {
		border-top: 2px solid #000; 
	}

	.note-item {
		display: grid;
		grid-template-columns: 160px 1fr;
		padding: 40px 0;
		border-bottom: 1px solid #eee;
		transition: all 0.25s cubic-bezier(0.2, 1, 0.3, 1); /* Slightly smoother "pop" */
		border-left: 0px solid #000;
		background-color: transparent; /* Explicitly clear */
	}

	/* --- THE INTERACTION (No Grey) --- */
	.note-item:hover {
		padding-left: 25px; /* Shifts content right */
		border-left: 6px solid #000; /* Reveals the vertical anchor */
		border-bottom-color: #000; /* Darkens the bottom line for focus */
	}

	/* --- META --- */
	.note-meta {
		display: flex;
		flex-direction: column;
		gap: 8px;
		font-family: ui-monospace, SFMono-Regular, monospace;
	}

	.date {
		font-size: 0.8rem;
		color: #999;
	}

	.category-label {
		font-size: 0.65rem;
		font-weight: 800;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		color: #000;
	}

	/* --- KILL BLUE LINKS --- */
	.note-link, 
	.note-link:link, 
	.note-link:visited, 
	.note-link:active {
		text-decoration: none !important;
		color: #000 !important;
	}

	h2 {
		font-size: 1.4rem;
		font-weight: 600;
		letter-spacing: -0.02em;
		margin: 0 0 10px 0;
		line-height: 1.3;
		transition: color 0.2s ease;
	}

	.note-item:hover h2 {
		color: #666; /* Title softens slightly on hover */
	}

	p {
		font-size: 1rem;
		color: #555;
		line-height: 1.5;
		margin-bottom: 15px;
	}

	/* --- TAGS --- */
	.tags-row { display: flex; gap: 10px; }
	.tag {
		font-family: ui-monospace, SFMono-Regular, monospace;
		font-size: 0.75rem;
		color: #bbb;
	}

	@media (max-width: 700px) {
		.note-item {
			grid-template-columns: 1fr;
			gap: 15px;
			padding: 30px 0;
		}
		.note-item:hover { 
			padding-left: 15px; 
		}
	}
</style>
