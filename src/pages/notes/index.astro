---
/* CULTURE NOTES - san serif 
  - Dynamic Multi-Tag Filtering (Client-side)
  - Bi-directional Sorting (Order-based)
  - Static Category Discovery
*/
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const notes = await getCollection('notes');

// Default Sort: Descending (Highest order first)
const sortedNotes = notes.sort((a, b) => b.data.order - a.data.order);

// Extract unique categories for the filter bar
const allCategories = [...new Set(notes.flatMap(n => n.data.category))].sort();
---

<Layout title="Notes | san serif">
	<main class="wrapper">

		<header class="page-header">
			<h1>Culture Notes</h1>
			<p class="page-subtitle">
				Beyond the dictionary: exploring the unspoken rules and nuances of language.
			</p>
			
			<div class="controls-container">
				<div class="filter-group">
					<span class="control-label">EXPLORE BY CATEGORY:</span>
					<div class="tag-cloud" id="tag-cloud">
						{allCategories.map(cat => (
							<button class="filter-tag" data-tag={cat.toLowerCase()}>
								{cat.toUpperCase()}
							</button>
						))}
					</div>
				</div>

				<div class="sort-group">
					<span class="control-label">ORDER:</span>
					<button id="sort-toggle" data-order="desc">NEWEST FIRST ↓</button>
				</div>
			</div>
		</header>

		<section class="notes-list" id="notes-container">
			{sortedNotes.map(note => (
				<article 
					class="note-item" 
					data-category={note.data.category.join(',').toLowerCase()}
					data-order={note.data.order}
				>

					<div class="note-meta">
						<span class="index">
							{note.data.order < 10 ? `0${note.data.order}` : note.data.order}
						</span>
						<div class="category-list">
							{note.data.category.map(cat => (
								<span class="category-label-static">
									{cat.toUpperCase()}
								</span>
							))}
						</div>
					</div>

					<div class="note-content">
						<a href={`/notes/${note.slug || note.id}`} class="note-link">
							<h2>{note.data.title}</h2>
						</a>
						<p>{note.data.description}</p>
					</div>

				</article>
			))}
		</section>

	</main>
</Layout>

<script is:inline>
	const container = document.getElementById('notes-container');
	const sortBtn = document.getElementById('sort-toggle');
	const items = Array.from(document.querySelectorAll('.note-item'));
	let activeTags = new Set();

	// 1. Multi-Tag Filtering Logic
	document.querySelectorAll('.filter-tag').forEach(btn => {
		btn.addEventListener('click', () => {
			const tag = btn.getAttribute('data-tag');
			
			if (activeTags.has(tag)) {
				activeTags.delete(tag);
				btn.classList.remove('active');
			} else {
				activeTags.add(tag);
				btn.classList.add('active');
			}
			
			applyFilters();
		});
	});

	function applyFilters() {
		items.forEach(item => {
			const itemTags = item.getAttribute('data-category').split(',');
			const isVisible = activeTags.size === 0 || [...activeTags].some(t => itemTags.includes(t));
			item.classList.toggle('hidden', !isVisible);
		});
	}

	// 2. Client-Side Sorting Logic
	sortBtn.addEventListener('click', () => {
		const currentOrder = sortBtn.getAttribute('data-order');
		const newOrder = currentOrder === 'asc' ? 'desc' : 'asc';
		
		sortBtn.setAttribute('data-order', newOrder);
		sortBtn.innerText = newOrder === 'asc' ? 'OLDEST FIRST ↑' : 'NEWEST FIRST ↓';

		const sortedItems = items.sort((a, b) => {
			const valA = parseInt(a.getAttribute('data-order'));
			const valB = parseInt(b.getAttribute('data-order'));
			return newOrder === 'asc' ? valA - valB : valB - valA;
		});

		container.innerHTML = '';
		sortedItems.forEach(el => container.appendChild(el));
	});
</script>

<style>
	.wrapper {
		max-width: 850px;
		margin: 0 auto;
		padding: 60px 20px 120px;
	}

	.page-header { margin-bottom: 40px; }

	h1 {
		font-size: 3rem;
		font-weight: 700;
		letter-spacing: -0.04em;
		margin-bottom: 15px;
		color: #000;
	}

	.page-subtitle {
		color: #666;
		font-size: 1.1rem;
		max-width: 800px;
		line-height: 1.5;
		margin-bottom: 30px;
	}

	.controls-container {
		border-top: 1px solid #eee;
		padding: 24px 0;
		display: flex;
		flex-direction: column;
		gap: 20px;
	}

	.control-label {
		font-family: ui-monospace, SFMono-Regular, monospace;
		font-size: 0.7rem;
		color: #999;
		margin-bottom: 10px;
		display: block;
		letter-spacing: 0.05em;
	}

	.tag-cloud {
		display: flex;
		flex-wrap: wrap;
		gap: 8px;
	}

	.filter-tag {
		background: none;
		border: 1px solid #eee;
		padding: 6px 14px;
		border-radius: 20px;
		font-size: 0.7rem;
		font-weight: 700;
		cursor: pointer;
		transition: all 0.2s;
		color: #666;
	}

	.filter-tag:hover { border-color: #000; color: #000; }
	.filter-tag.active { background: #000; color: #fff; border-color: #000; }

	#sort-toggle {
		background: none;
		border: none;
		font-family: ui-monospace, SFMono-Regular, monospace;
		font-size: 0.8rem;
		font-weight: 700;
		cursor: pointer;
		padding: 0;
		text-decoration: underline;
		text-underline-offset: 4px;
	}

	.notes-list { border-top: 2px solid #000; }

	.note-item {
		display: grid;
		grid-template-columns: 160px 1fr;
		padding: 40px 0;
		border-bottom: 1px solid #eee;
		transition: all 0.25s cubic-bezier(0.2, 1, 0.3, 1);
	}

	.note-item.hidden { display: none; }

	.note-item:hover {
		padding-left: 25px;
		box-shadow: inset 6px 0 0 0 #000;
		border-bottom-color: #000;
	}

	.note-meta {
		display: flex;
		flex-direction: column;
		gap: 8px;
		font-family: ui-monospace, SFMono-Regular, monospace;
	}

	.index { 
		font-size: 1rem; 
		color: #000; 
		font-weight: 700;
		letter-spacing: 0.1em;
	}
	
	.index::before {
		content: "NOTE ";
		font-size: 0.65rem;
		color: #999;
		letter-spacing: 0.05em;
	}

	.category-list { display: flex; flex-direction: column; gap: 4px; }

	.category-label-static {
		font-size: 0.65rem;
		font-weight: 800;
		color: #bbb;
		letter-spacing: 0.1em;
	}

	.note-link { text-decoration: none !important; color: #000 !important; }

	h2 { font-size: 1.4rem; font-weight: 600; margin: 0 0 10px 0; line-height: 1.3; }
	p { font-size: 1rem; color: #555; line-height: 1.5; }

	@media (max-width: 700px) {
		.note-item { grid-template-columns: 1fr; gap: 15px; padding: 30px 0; }
		.note-item:hover { padding-left: 15px; box-shadow: inset 4px 0 0 0 #000; }
	}
</style>