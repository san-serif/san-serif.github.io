---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Support | san serif">
	<main class="support-wrapper">
		<header>
			<h1>Support</h1>
			<p id="support-desc">Need help with our apps? Send a message below.</p>
		</header>

		<div id="success-state" style="display: none;">
			<div class="success-message">
				<p>Thank you for your message.</p>
			</div>
		</div>

		<form id="support-form" action="https://formsubmit.co/765cfb8e23936c8967ac157a317840c9" method="POST" class="contact-form">
			<input type="hidden" name="_next" id="next-url">
			<input type="hidden" name="_subject" value="san serif Support Request">
			<input type="hidden" name="_captcha" value="false">

			<div class="form-group">
				<label>Name</label>
				<input type="text" name="name" required spellcheck="false" />
			</div>

			<div class="form-group">
				<label>Email</label>
				<input type="email" name="email" required spellcheck="false" />
			</div>

			<div class="form-group">
				<label>Message</label>
				<textarea name="message" rows="6" required></textarea>
			</div>

			<button type="submit" id="submit-btn">Send Message</button>
		</form>

		<div class="footer-link">
			<a href="/">← Return to san serif</a>
		</div>
	</main>
</Layout>

<script is:inline>
	// 1. Set the dynamic redirect URL
	const nextInput = document.getElementById('next-url');
	if (nextInput) {
		nextInput.value = window.location.origin + window.location.pathname + '?status=success';
	}

	const form = document.getElementById('support-form');
	const btn = document.getElementById('submit-btn');

	// 2. Button loading state
	if (form && btn) {
		form.onsubmit = () => {
			btn.innerText = 'Sending...';
			btn.style.opacity = '0.4';
			btn.style.pointerEvents = 'none';
		};
	}

	// 3. UI Swap on success
	const urlParams = new URLSearchParams(window.location.search);
	if (urlParams.get('status') === 'success') {
		const success = document.getElementById('success-state');
		const headerDesc = document.getElementById('support-desc');

		if (form) form.style.display = 'none';
		if (headerDesc) headerDesc.style.display = 'none';
		if (success) success.style.display = 'block';
	}
</script>

<style>
	.support-wrapper { max-width: 500px; margin: 0 auto; padding: 80px 20px; }
	
	h1 { 
		font-size: 2.2rem; 
		letter-spacing: -0.04em; 
		margin-bottom: 8px; 
		font-weight: 700;
		color: #000;
	}
	
	p { color: #666; margin-bottom: 40px; line-height: 1.6; font-size: 0.95rem; }

	.contact-form { display: flex; flex-direction: column; gap: 32px; }
	.form-group { display: flex; flex-direction: column; gap: 8px; }
	
	label { 
		font-family: ui-monospace, SFMono-Regular, monospace; 
		font-size: 0.65rem; 
		text-transform: uppercase; 
		color: #999; 
		font-weight: 700; 
		letter-spacing: 0.05em;
	}

	input, textarea { 
		padding: 10px 0; 
		border: none;
		border-bottom: 1px solid #eee;
		border-radius: 0;
		font-size: 1rem; 
		background: transparent; 
		width: 100%;
		box-sizing: border-box;
		transition: border-color 0.2s ease;
	}

	input:focus, textarea:focus {
		outline: none;
		border-bottom-color: #000;
	}

	button { 
		background: #000; 
		color: #fff; 
		border: none; 
		padding: 16px; 
		margin-top: 10px;
		border-radius: 4px; 
		font-size: 0.9rem; 
		font-weight: 600; 
		cursor: pointer; 
	}

	/* The "San Serif" Success Message */
	.success-message p {
		color: #000;
		font-weight: 500;
		font-size: 1rem;
		border-left: 2px solid #000; /* Minimal architectural accent */
		padding-left: 20px;
		margin: 20px 0 60px;
	}

	.footer-link { 
		margin-top: 80px; 
		padding-top: 20px; 
		border-top: 1px solid #f5f5f5;
	}
	
	.footer-link a { 
		color: #bbb; 
		text-decoration: none; 
		font-size: 0.8rem; 
		font-weight: 500;
	}

	.footer-link a:hover { color: #000; }
</style>